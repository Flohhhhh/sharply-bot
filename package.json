{
  "name": "discord-bot-template",
  "version": "1.0.0",
  "description": "Type-safe Discord bot template with Node.js, TypeScript, ESLint, and Prettier",
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "preinstall": "npx only-allow npm",
    "start": "tsx ./src/index.ts",
    "deploy-commands": "tsx ./src/deploy.ts",
    "clear-commands": "tsx ./src/clear-commands.ts",
    "clear-commands:global": "tsx ./src/clear-commands.ts --global",
    "fmt": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "npm run lint && npm run format:check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.10",
    "croner": "^9.1.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.4.1",
    "pino": "^10.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.19.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
