# Discord Bot credentials
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_APPLICATION_ID=your_APPLICATION_ID_here

# Optional: Deploy commands to a specific guild for faster updates (development)
DISCORD_GUILD_ID=your_guild_id_here

# Optional: Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Optional: Weekly public-repo digest → Discord incoming webhook (enable only with both URL + repo).
# Also posts once when the bot starts (plus the cron schedule).
# WEEKLY_DIGEST_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# WEEKLY_DIGEST_GITHUB_REPO=owner/repo
# WEEKLY_DIGEST_CRON=0 9 * * 1
# WEEKLY_DIGEST_WINDOW_DAYS=7
# GITHUB_TOKEN=
# TZ=UTC

# Optional: LLM (OpenAI-compatible /chat/completions) to rewrite digest as release notes
# WEEKLY_DIGEST_LLM_API_KEY=
# WEEKLY_DIGEST_LLM_BASE_URL=https://api.openai.com/v1
# WEEKLY_DIGEST_LLM_MODEL=gpt-4o-mini
